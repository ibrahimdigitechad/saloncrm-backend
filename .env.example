# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/saloncrm

# JWT
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-minimum-32-chars

# App
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# WhatsApp (Meta Cloud API)
WA_VERIFY_TOKEN=saloncrm_verify_token

# Optional: Default Resend key (tenants override with their own)
RESEND_API_KEY=re_xxxx
